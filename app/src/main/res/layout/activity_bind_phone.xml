<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <View
        android:layout_width="230dp"
        android:layout_height="230dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-76dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_auth_corner_glow" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="760dp">

            <LinearLayout
                android:id="@+id/layoutForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingTop="96dp"
                android:paddingEnd="32dp"
                android:paddingBottom="28dp">

                <FrameLayout
                    android:layout_width="74dp"
                    android:layout_height="48dp">

                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="start|center_vertical"
                        android:background="@drawable/bg_auth_circle_cyan" />

                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="end|center_vertical"
                        android:background="@drawable/bg_auth_circle_yellow" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="绑定手机号"
                    android:textColor="#171717"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="绑定后可使用手机号和密码登录"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="30dp"
                    android:background="@drawable/bg_login_input"
                    android:hint="手机号"
                    android:inputType="phone"
                    android:maxLength="11"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:singleLine="true"
                    android:textColor="#222222"
                    android:textColorHint="#C7C7C7"
                    android:textSize="14sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_login_input">

                    <EditText
                        android:id="@+id/etCode"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="验证码"
                        android:inputType="number"
                        android:maxLength="6"
                        android:paddingStart="20dp"
                        android:paddingEnd="116dp"
                        android:singleLine="true"
                        android:textColor="#222222"
                        android:textColorHint="#C7C7C7"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/btnSendCode"
                        android:layout_width="108dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:gravity="center"
                        android:text="获取验证码"
                        android:textColor="@color/primary"
                        android:textSize="13sp" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_login_input">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="设置6-20位登录密码"
                        android:inputType="textPassword"
                        android:maxLength="20"
                        android:paddingStart="20dp"
                        android:paddingEnd="54dp"
                        android:singleLine="true"
                        android:textColor="#222222"
                        android:textColorHint="#C7C7C7"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/btnPasswordVisibility"
                        android:layout_width="50dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="显示或隐藏密码"
                        android:padding="15dp"
                        android:src="@drawable/ic_eye_off" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_login_input">

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="再次输入密码"
                        android:inputType="textPassword"
                        android:maxLength="20"
                        android:paddingStart="20dp"
                        android:paddingEnd="54dp"
                        android:singleLine="true"
                        android:textColor="#222222"
                        android:textColorHint="#C7C7C7"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/btnConfirmPasswordVisibility"
                        android:layout_width="50dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="显示或隐藏确认密码"
                        android:padding="15dp"
                        android:src="@drawable/ic_eye_off" />
                </FrameLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBind"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="34dp"
                    android:background="@drawable/bg_login_primary_button"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:text="绑定手机号"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutBound"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingTop="116dp"
                android:paddingEnd="32dp"
                android:paddingBottom="32dp"
                android:visibility="gone">

                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="64dp">

                    <View
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="start|center_vertical"
                        android:background="@drawable/bg_auth_circle_cyan" />

                    <View
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="end|center_vertical"
                        android:background="@drawable/bg_auth_circle_yellow" />

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:contentDescription="手机号已绑定"
                        android:src="@drawable/ic_check"
                        android:tint="@color/white" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:text="手机号已绑定"
                    android:textColor="#171717"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBoundPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:textColor="@color/primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="当前账号已完成手机号绑定\n如需更换请联系客服"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp" />
            </LinearLayout>
        </FrameLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="8dp"
        android:layout_marginTop="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="返回"
        android:padding="13dp"
        android:src="@drawable/ic_arrow_back_black" />
</FrameLayout>
