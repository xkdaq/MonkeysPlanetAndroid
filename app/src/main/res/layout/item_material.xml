<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginVertical="14dp"
        android:orientation="vertical">


        <!-- 标题行：置顶标签 + 标题 -->
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTopTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_tag_top"
                android:paddingHorizontal="5dp"
                android:paddingVertical="1dp"
                android:text="置顶"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.3"
                android:maxLines="2"
                android:textColor="#333333"
                android:textSize="15sp" />
        </androidx.appcompat.widget.LinearLayoutCompat>

        <!-- 分类标签行 -->
        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#888888"
            android:textSize="11sp" />

        <!-- 网盘标识行 -->
        <LinearLayout
            android:id="@+id/panRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvBaiduHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_tag_baidu"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="百度网盘"
                android:textColor="#2196F3"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvQuarkHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_quark"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="夸克网盘"
                android:textColor="#FF6D00"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

    </androidx.appcompat.widget.LinearLayoutCompat>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginHorizontal="12dp"
        android:background="#F0F0F0" />


</LinearLayout>
