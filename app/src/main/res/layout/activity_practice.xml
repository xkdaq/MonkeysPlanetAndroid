<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

<LinearLayout
    android:id="@+id/contentLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:visibility="gone">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:orientation="vertical">

        <!-- 顶部导航 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_arrow_back_black" />

                <!-- 进度 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvCurrentIndex"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textColor="@color/primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:text="/20"
                        android:textColor="@color/text_hint"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- 模式切换 -->
                <LinearLayout
                    android:id="@+id/modeSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_mode_switch"
                    android:orientation="horizontal"
                    android:padding="2dp">

                    <TextView
                        android:id="@+id/btnModeAnswer"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_mode_active"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="答题"
                        android:textColor="@color/primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/btnModeStudy"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="背题"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 进度条 -->
            <View
                android:id="@+id/progressBarBg"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="10dp"
                android:background="#E0E0E0" />

            <View
                android:id="@+id/progressBarFill"
                android:layout_width="0dp"
                android:layout_height="3dp"
                android:layout_marginTop="-3dp"
                android:background="@color/primary" />
        </LinearLayout>

        <!-- 题目内容区域 -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- 题目卡片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_practice_card_round"
                    android:orientation="vertical"
                    android:padding="16dp"
                    tools:ignore="WebViewLayout">

                    <TextView
                        android:id="@+id/tvQuestionType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/bg_question_type_tag"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:textColor="@color/primary"
                        android:textSize="12sp" />

                    <WebView
                        android:id="@+id/webViewQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent" />
                </LinearLayout>

                <!-- 选项列表 -->
                <LinearLayout
                    android:id="@+id/optionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- 多选题提交按钮 -->
                <TextView
                    android:id="@+id/btnSubmitAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_primary_button"
                    android:gravity="center"
                    android:text="提交答案"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- 答案解析区域 -->
                <LinearLayout
                    android:id="@+id/analysisLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_practice_card_round"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:visibility="gone">

                    <!-- 答案对比 -->
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_practice_gray"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="正确答案"
                                android:textColor="@color/text_hint"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvCorrectAnswer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textColor="@color/primary"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </androidx.appcompat.widget.LinearLayoutCompat>

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="你的答案"
                                android:textColor="@color/text_hint"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvUserAnswer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </androidx.appcompat.widget.LinearLayoutCompat>
                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <!-- 解析内容 -->
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/analysisContentLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_practice_white"
                        android:orientation="vertical"
                        android:padding="12dp"
                        tools:ignore="WebViewLayout">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_analysis_bar"
                            android:drawablePadding="6dp"
                            android:text="文本解析"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <WebView
                            android:id="@+id/webViewAnalysis"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@android:color/transparent" />
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="16dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- 底部操作栏 -->
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/white"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <!-- 上一题 -->
            <TextView
                android:id="@+id/btnPrev"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_nav_btn"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="上一题"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 中间操作按钮 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_practice_gray"
                android:orientation="horizontal"
                android:padding="4dp">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:id="@+id/btnCard"
                    android:layout_width="42dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▦"
                        android:textColor="@color/text_hint"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="答题卡"
                        android:textColor="@color/text_hint"
                        android:textSize="9sp" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:id="@+id/btnFavorite"
                    android:layout_width="42dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFavoriteIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☆"
                        android:textColor="@color/text_hint"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvFavoriteText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="收藏"
                        android:textColor="@color/text_hint"
                        android:textSize="9sp" />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </LinearLayout>

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 下一题/交卷 -->
            <TextView
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_nav_btn_primary"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="下一题"
                android:textColor="@color/white"
                android:textSize="13sp" />
        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.appcompat.widget.LinearLayoutCompat>

</LinearLayout>

<!-- Loading遮罩层 -->
<LinearLayout
    android:id="@+id/loadingLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@color/white">

    <ProgressBar
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:indeterminateTint="@color/primary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="加载中..."
        android:textSize="14sp"
        android:textColor="@color/text_hint" />
</LinearLayout>

</FrameLayout>
