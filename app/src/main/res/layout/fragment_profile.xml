<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <View
        android:layout_width="210dp"
        android:layout_height="210dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-84dp"
        android:layout_marginEnd="-62dp"
        android:background="@drawable/bg_auth_corner_glow" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="10dp"
            android:text="我的"
            android:textSize="17sp"
            android:textStyle="bold" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E3E9E5"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:id="@+id/layoutLoggedIn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="16dp"
                            android:paddingTop="16dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="16dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/ivAvatar"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_avatar_placeholder"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_avatar_default"
                                app:shapeAppearanceOverlay="@style/CircleImageStyle"
                                app:strokeColor="#BDEFD2"
                                app:strokeWidth="3dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="13dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvNickname"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:ellipsize="end"
                                    android:singleLine="true"
                                    android:text="微信用户"
                                    android:textColor="@color/text_primary"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvUserId"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:textColor="@color/text_hint"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/btnEditProfile"
                                android:layout_width="52dp"
                                android:layout_height="30dp"
                                android:background="@drawable/bg_profile_edit_button"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:text="编辑"
                                android:textColor="@color/primary"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutNotLoggedIn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:paddingStart="22dp"
                            android:paddingTop="18dp"
                            android:paddingEnd="22dp"
                            android:paddingBottom="18dp"
                            android:visibility="gone">

                            <FrameLayout
                                android:layout_width="70dp"
                                android:layout_height="50dp">

                                <View
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:layout_gravity="start|center_vertical"
                                    android:background="@drawable/bg_auth_circle_cyan" />

                                <com.google.android.material.imageview.ShapeableImageView
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:layout_gravity="end|center_vertical"
                                    android:background="@drawable/bg_auth_circle_yellow"
                                    android:padding="8dp"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_avatar_default"
                                    app:shapeAppearanceOverlay="@style/CircleImageStyle" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="欢迎来到猴哥星球"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="登录后同步学习记录与账号信息"
                                android:textColor="@color/text_hint"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/btnLogin"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:layout_marginTop="15dp"
                                android:background="@drawable/bg_login_primary_button"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:text="立即登录"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvAccountSection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="16dp"
                    android:text="账号与学习"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAccount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E3E9E5"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <include
                            android:id="@+id/menuBindPhone"
                            layout="@layout/item_profile_menu" />

                        <View style="@style/MenuDivider" />

                        <include
                            android:id="@+id/menuChangePassword"
                            layout="@layout/item_profile_menu" />

                        <View
                            android:id="@+id/dividerChangePassword"
                            style="@style/MenuDivider" />

                        <include
                            android:id="@+id/menuStudyRecords"
                            layout="@layout/item_profile_menu" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="16dp"
                    android:text="更多服务"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E3E9E5"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <include
                            android:id="@+id/menuSettings"
                            layout="@layout/item_profile_menu" />

                        <View style="@style/MenuDivider" />

                        <include
                            android:id="@+id/menuAbout"
                            layout="@layout/item_profile_menu" />

                        <View style="@style/MenuDivider" />

                        <include
                            android:id="@+id/menuFeedback"
                            layout="@layout/item_profile_menu" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#F3DADA"
                    app:strokeWidth="1dp">

                    <TextView
                        android:id="@+id/btnLogout"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="退出登录"
                        android:textColor="@color/text_red"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>


    </androidx.appcompat.widget.LinearLayoutCompat>


</FrameLayout>
