<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <View
        android:layout_width="230dp"
        android:layout_height="230dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-76dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_auth_corner_glow" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="700dp"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingTop="96dp"
            android:paddingEnd="32dp"
            android:paddingBottom="32dp">

            <FrameLayout
                android:layout_width="74dp"
                android:layout_height="48dp">

                <View
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@drawable/bg_auth_circle_cyan" />

                <View
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="@drawable/bg_auth_circle_yellow" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="您好，欢迎登录！"
                android:textColor="#171717"
                android:textSize="25sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="44dp"
                android:background="@drawable/bg_login_input"
                android:hint="手机号"
                android:inputType="phone"
                android:maxLength="11"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:singleLine="true"
                android:textColor="#222222"
                android:textColorHint="#C7C7C7"
                android:textSize="14sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_login_input">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="密码"
                    android:inputType="textPassword"
                    android:paddingStart="20dp"
                    android:paddingEnd="54dp"
                    android:singleLine="true"
                    android:textColor="#222222"
                    android:textColorHint="#C7C7C7"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnPasswordVisibility"
                    android:layout_width="50dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="显示或隐藏密码"
                    android:padding="15dp"
                    android:src="@drawable/ic_eye_off" />
            </FrameLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="46dp"
                android:background="@drawable/bg_login_primary_button"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                android:text="登录"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvRegister"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="去注册"
                android:textColor="@color/primary"
                android:textSize="13sp" />

            <Space
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="I THINK I CAN AND I WILL"
                android:textColor="#D7D7D7"
                android:textSize="9sp" />
        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="8dp"
        android:layout_marginTop="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="返回"
        android:padding="13dp"
        android:src="@drawable/ic_arrow_back_black" />
</FrameLayout>
