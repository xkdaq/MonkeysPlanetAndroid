# ============================================
# 敏感配置模板 - 复制为 secrets.properties 并填入真实值
# ============================================
# 使用方式: cp secrets.properties.example secrets.properties 并编辑

# AES 加密密钥（16位字符串）
AES_KEY=YOUR_AES_KEY_HERE

# AES 初始化向量（16位字符串）
AES_IV=YOUR_AES_IV_HERE

# 接口签名密钥
SIGN_KEY=YOUR_SIGN_KEY_HERE

# API 基础地址
BASE_URL=https://your-api-domain.com

# 文章接口版本号
ARTICLE_API_VERSION=10

# 资料接口版本号
MATERIAL_API_VERSION=8
